{
  "name": "whatsapp-bulk-tool",
  "version": "1.0.0",
  "description": "WhatsApp Bulk Message Automation Tool",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "npm --prefix backend install && npm --prefix frontend install",
    "build": "npm --prefix frontend run build",
    "start": "node --experimental-sqlite backend/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node --experimental-sqlite index.js",
    "dev:frontend": "cd frontend && npx vite --host",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
