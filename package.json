{
  "name": "whatsapp-bulk-tool",
  "version": "1.0.0",
  "description": "WhatsApp Bulk Message Automation Tool",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node index.js",
    "dev:frontend": "cd frontend && npx vite --host",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
