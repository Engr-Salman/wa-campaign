# Public URL of the deployed backend API.
#
# Leave this empty for local development — the Vite dev server proxies
# /api and /socket.io to http://localhost:3001 automatically.
#
# For a Netlify (or other static-host) production build, set this to the
# full origin of your backend, e.g.:
#   VITE_API_URL=https://wa-backend.up.railway.app
VITE_API_URL=
