# ────────────────────────────────────────────────────────────────────
# Bulk Email Platform — environment variables
# Copy this file to `.env` and fill in real values.
# ────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
APP_NAME="Bulk Email Platform"
APP_URL=http://localhost:3000
# Public URL used in tracking pixels, unsubscribe links, click redirects.
# In production this MUST be HTTPS and routable from recipients' mail clients.
PUBLIC_TRACKING_URL=http://localhost:3000

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://bulkmail:bulkmail@localhost:5432/bulkmail?schema=public

# Redis (used by BullMQ queue and rate limiter)
REDIS_URL=redis://localhost:6379

# Master encryption key for provider credentials (SMTP passwords, API keys)
# Must be a 32-byte base64 string.
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=replace-me-32-byte-base64-encoded-key===

# Default sending concurrency (worker) — how many emails in flight at once
SEND_WORKER_CONCURRENCY=10
# Default global send rate ceiling (msgs/sec) as a safety floor
GLOBAL_MAX_SENDS_PER_SECOND=20

# Large send confirmation threshold (UI warning)
LARGE_SEND_THRESHOLD=5000

# Upload limits
MAX_CSV_UPLOAD_MB=25
MAX_ATTACHMENT_MB=10

# Logging
LOG_LEVEL=info
