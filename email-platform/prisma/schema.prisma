// Bulk Email Platform — Prisma schema
// ────────────────────────────────────────────────────────────────────
// Design goals:
// - Multi-tenant via Organization
// - Full campaign lifecycle tracking at per-recipient granularity
// - Append-only EmailEvent log (open/click/bounce/complain/unsubscribe/fail)
// - Append-only AuditLog for sensitive actions
// - Suppression list is scoped per-Organization and enforced before every send
// - Indexes chosen to support the hottest read paths (campaign dashboards,
//   recipient lookups by token, suppression checks, event time-series)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenancy & users ─────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  // Org-wide compliance defaults shown in footers.
  legalName        String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?
  // Soft defaults applied to new senders.
  defaultFromName  String?
  defaultFromEmail String?
  footerHtml       String?
  // Feature flags / compliance toggles
  requireDoubleOptIn   Boolean @default(false)
  enforceUnsubFooter   Boolean @default(true)
  largeSendThreshold   Int     @default(5000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     Membership[]
  senderAccounts  SenderAccount[]
  contacts        Contact[]
  contactLists    ContactList[]
  contactTags     ContactTag[]
  customFields    CustomField[]
  segments        Segment[]
  templates       Template[]
  campaigns       Campaign[]
  suppression     SuppressionEntry[]
  importJobs      ImportJob[]
  auditLogs       AuditLog[]
  webhookEvents   WebhookEvent[]
  apiKeys         ApiKey[]
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  ANALYST
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerifiedAt  DateTime?
  name             String?
  passwordHash     String?
  image            String?
  // 2FA-ready placeholder; enforced in future release.
  totpSecret       String?
  twoFactorEnabled Boolean   @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memberships   Membership[]
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]
  passwordResetTokens PasswordResetToken[]
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role     @default(MANAGER)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// NextAuth tables
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Sender accounts / provider connections ─────────────────────────

enum SenderType {
  SMTP
  SES
  SENDGRID
  MAILGUN
  RESEND
  POSTMARK
}

enum SenderStatus {
  PENDING
  VERIFIED
  FAILED
  DISABLED
}

model SenderAccount {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           SenderType   @default(SMTP)
  status         SenderStatus @default(PENDING)
  fromName       String
  fromEmail      String
  replyTo        String?
  // Encrypted JSON blob with provider-specific config (SMTP host/port/auth, API keys)
  // Stored as ciphertext using AES-256-GCM.
  configEncrypted Bytes
  // Rate / warmup controls
  maxPerSecond   Int          @default(5)
  maxPerMinute   Int          @default(120)
  maxPerHour     Int          @default(5000)
  maxPerDay      Int          @default(50000)
  dailySentCount Int          @default(0)
  dailyCounterDay DateTime?
  lastError      String?
  lastVerifiedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@index([organizationId, status])
}

// ── Contacts, lists, tags, segments ────────────────────────────────

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  PENDING
  CLEANED // hard-bounced or marked undeliverable
  COMPLAINED
}

enum BounceState {
  NONE
  SOFT
  HARD
}

model CustomField {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  label          String
  type           String   @default("string") // string|number|date|boolean
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
}

model Contact {
  id              String        @id @default(cuid())
  organizationId  String
  email           String
  firstName       String?
  lastName        String?
  // Freeform normalized custom attributes as JSON.
  attributes      Json          @default("{}")
  status          ContactStatus @default(SUBSCRIBED)
  bounceState     BounceState   @default(NONE)
  // Consent / source tracking
  source          String?
  consentAt       DateTime?
  consentIp       String?
  // Engagement
  lastSentAt      DateTime?
  lastOpenedAt    DateTime?
  lastClickedAt   DateTime?
  engagementScore Int           @default(0)
  // Housekeeping
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listMembers  ContactListMember[]
  tagLinks     ContactTagLink[]
  recipients   CampaignRecipient[]
  events       EmailEvent[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, bounceState])
}

model ContactList {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      ContactListMember[]
  campaigns    CampaignListTarget[]

  @@unique([organizationId, name])
}

model ContactListMember {
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
}

model ContactTag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  links        ContactTagLink[]

  @@unique([organizationId, name])
}

model ContactTagLink {
  tagId     String
  contactId String

  tag     ContactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  contact Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([tagId, contactId])
  @@index([contactId])
}

model Segment {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  // Stored filter DSL; see src/server/services/segments.ts
  definition     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    CampaignSegmentTarget[]

  @@unique([organizationId, name])
}

// ── Templates ──────────────────────────────────────────────────────

enum TemplateKind {
  MJML
  HTML
}

model Template {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  kind           TemplateKind @default(MJML)
  source         String       @db.Text
  // Cached compiled HTML for fast rendering/preview.
  compiledHtml   String?      @db.Text
  subject        String?
  preheader      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  variants     CampaignVariant[]

  @@unique([organizationId, name])
}

// ── Campaigns ──────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  CANCELED
  FAILED
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  subject        String
  preheader      String?
  status         CampaignStatus @default(DRAFT)
  senderAccountId String?
  templateId     String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  timezone       String         @default("UTC")
  // A/B testing (optional)
  abEnabled      Boolean        @default(false)
  abSplitPercent Int            @default(20)
  abWinnerMetric String?        // "open" | "click"
  // UTM defaults
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  // Safety
  requireConfirmation Boolean   @default(true)
  confirmedAt    DateTime?
  confirmedById  String?
  // Progress counters (denormalized for fast dashboards)
  totalRecipients Int           @default(0)
  sentCount       Int           @default(0)
  deliveredCount  Int           @default(0)
  openCount       Int           @default(0)
  clickCount      Int           @default(0)
  bounceCount     Int           @default(0)
  complaintCount  Int           @default(0)
  unsubCount      Int           @default(0)
  failedCount     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderAccount SenderAccount?   @relation(fields: [senderAccountId], references: [id])
  template      Template?        @relation(fields: [templateId], references: [id])
  variants      CampaignVariant[]
  listTargets   CampaignListTarget[]
  segmentTargets CampaignSegmentTarget[]
  recipients    CampaignRecipient[]
  events        EmailEvent[]

  @@index([organizationId, status])
  @@index([scheduledAt])
}

model CampaignVariant {
  id         String  @id @default(cuid())
  campaignId String
  label      String  // "A", "B", ...
  subject    String
  templateId String?
  weight     Int     @default(50)

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id])
  recipients CampaignRecipient[]

  @@unique([campaignId, label])
}

model CampaignListTarget {
  campaignId String
  listId     String

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  list     ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([campaignId, listId])
}

model CampaignSegmentTarget {
  campaignId String
  segmentId  String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([campaignId, segmentId])
}

enum RecipientStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
  SKIPPED
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  contactId  String
  variantId  String?
  status     RecipientStatus @default(PENDING)
  // Per-recipient opaque tokens for tracking and unsub.
  // Generated once at materialization and never re-used.
  trackingToken String        @unique
  unsubToken    String        @unique
  // Send lifecycle
  attemptCount Int            @default(0)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime?
  firstOpenedAt DateTime?
  firstClickedAt DateTime?
  bouncedAt     DateTime?
  complainedAt  DateTime?
  unsubscribedAt DateTime?
  failureReason String?
  messageId     String?  // provider message-id
  snapshotHtml  String?  @db.Text // rendered HTML for this recipient (optional)
  snapshotSubject String?
  createdAt     DateTime @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  variant  CampaignVariant? @relation(fields: [variantId], references: [id])
  events   EmailEvent[]

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([status])
}

enum EmailEventType {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
  DEFERRED
}

model EmailEvent {
  id          String         @id @default(cuid())
  campaignId  String?
  recipientId String?
  contactId   String?
  type        EmailEventType
  // Free-form metadata (URL for clicks, bounce code, user agent, IP)
  metadata    Json           @default("{}")
  occurredAt  DateTime       @default(now())

  campaign  Campaign?          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient CampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  contact   Contact?           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId, type, occurredAt])
  @@index([recipientId, type])
  @@index([contactId, occurredAt])
}

// ── Suppression list ───────────────────────────────────────────────

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE_HARD
  COMPLAINT
  MANUAL
  IMPORT
}

model SuppressionEntry {
  id             String            @id @default(cuid())
  organizationId String
  email          String
  reason         SuppressionReason
  note           String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, reason])
}

// ── Imports, audit, webhooks, api keys ─────────────────────────────

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ImportJob {
  id             String       @id @default(cuid())
  organizationId String
  fileName       String
  status         ImportStatus @default(PENDING)
  totalRows      Int          @default(0)
  importedCount  Int          @default(0)
  updatedCount   Int          @default(0)
  skippedCount   Int          @default(0)
  invalidCount   Int          @default(0)
  errorReport    Json?
  targetListId   String?
  mapping        Json?
  createdAt      DateTime     @default(now())
  finishedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String?
  entityId       String?
  metadata       Json     @default("{}")
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
}

model WebhookEvent {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  eventType      String
  payload        Json
  processedAt    DateTime?
  error          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ApiKey {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  prefix         String   @unique
  tokenHash      String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
